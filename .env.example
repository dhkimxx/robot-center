APP_ENV=development
APP_SERVER_HTTP_ADDR=:8080
APP_SERVER_HOST_PORT=8080
APP_SERVER_PUBLIC_URL=http://localhost:8080
APP_SERVER_INTERNAL_URL=http://app-server:8080
WEB_STATIC_DIR=/app/web
RECORDER_WORKER_INTERNAL_URL=http://recorder-worker:8082
STORE_DRIVER=postgres

POSTGRES_DB=robot_center
POSTGRES_USER=robot_center
POSTGRES_PASSWORD=robot_center
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=robot-center
MINIO_INTERNAL_URL=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

TURN_REALM=robot-center.local
TURN_USERNAME=robot
TURN_PASSWORD=change-me-turn-pass
TURN_PUBLIC_IP=auto
TURN_DOCKER_EXTERNAL_IP=127.0.0.1
TURN_DOCKER_RELAY_IP=172.28.0.10
DOCKER_BRIDGE_SUBNET=172.28.0.0/16
TURN_HOST_PORT=3478
TURN_RELAY_MIN_PORT=49160
TURN_RELAY_MAX_PORT=49300

SFU_WS_PUBLIC_BASE_URL=ws://localhost:8080
SFU_WS_INTERNAL_BASE_URL=ws://localhost:8080
TURN_PUBLIC_URL=turn:127.0.0.1:3478?transport=udp
TURN_INTERNAL_URL=turn:127.0.0.1:3478?transport=udp

RECORDER_WORKER_HTTP_ADDR=:8082
RECORDER_WORKER_HOST_PORT=8082
RECORDER_WORKER_POLL_INTERVAL=5s
RECORDING_CHUNK_DURATION=10m
