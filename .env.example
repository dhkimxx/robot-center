APP_ENV=development
APP_SERVER_HTTP_ADDR=:8080
APP_SERVER_HOST_PORT=8080
APP_SERVER_PUBLIC_URL=http://localhost:8080
WEB_STATIC_DIR=/app/web
RECORDER_WORKER_URL=http://localhost:8082
STORE_DRIVER=postgres

POSTGRES_DB=robot_center
POSTGRES_USER=robot_center
POSTGRES_PASSWORD=robot_center
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=robot-center
